<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Grocery.App.ViewModels"
             x:Class="Grocery.App.Views.ProductCategoriesView"
             Title="{Binding CategoryName}">
    <Shell.TitleView>
        <Grid>
            <Label Text="ProductCategorieën" FontSize="Large" HorizontalOptions="Center" VerticalOptions="Center" />
        </Grid>
    </Shell.TitleView>

    <Border Stroke="#C49B33" StrokeThickness="4" Padding="10" Margin="10" HorizontalOptions="Center">
        <Grid RowDefinitions="Auto,*">
            <Label Grid.Row="0" 
                   Text="{Binding CategoryName}" 
                   FontSize="Large" 
                   HorizontalOptions="Center" 
                   Margin="0,10,0,10" />
            
            <CollectionView Grid.Row="1" 
                           ItemsSource="{Binding Products}" 
                           EmptyView="Geen producten gevonden in deze categorie">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame Margin="10" Padding="10" BorderColor="Gray">
                            <StackLayout>
                                <Label Text="{Binding Name}" FontAttributes="Bold" />
                                <Label Text="{Binding Price, StringFormat='Prijs: €{0:F2}'}" />
                                <Label Text="{Binding Stock, StringFormat='Voorraad: {0}'}" />
                            </StackLayout>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Grid>
    </Border>
</ContentPage>
